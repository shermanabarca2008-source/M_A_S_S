<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.0">

    <persistence-unit name="jbrewPU" transaction-type="JTA">
        <jta-data-source>jdbc/jbrewDS</jta-data-source>

        <properties>
            <!-- 1. Configuración de generación / actualización de tablas (esquema de BD) -->
            <!-- Configuración de Jakarta persistence puede ser: none, create, drop-and-create, drop -->
            <property name="jakarta.persistence.schema-generation.database.action" value="drop-and-create"/>

            <!-- Configuración de EclipseLink values: none, drop-and-create-tables, create-tables, create-or-extend-tables -->
            <!--property name="eclipselink.ddl-generation" value="create-or-extend-tables"/-->

            <!-- database = ejecuta los comandos DDL directamente en la base de datos -->
            <property name="eclipselink.ddl-generation.output-mode" value="database"/>

            <!-- 2. Cargar script de inicialización de la BD -->
            <property name="jakarta.persistence.sql-load-script-source"  value="db/initial-data.sql"/>

            <!-- EclipseLink — proveedor JPA nativo de Open Liberty -->
            <property name="eclipselink.logging.level"      value="FINE"/>
            <property name="eclipselink.logging.level.sql"  value="FINE"/>
            <!-- Disable parameter logging to avoid EclipseLink 4.0.9 NPE bug on null UUID values -->
            <property name="eclipselink.logging.parameters" value="false"/>

            <property name="eclipselink.jdbc.bind-parameters"  value="true"/>

            <property name="eclipselink.target-database" value="org.eclipse.persistence.platform.database.PostgreSQLPlatform"/>
            <!-- Weaving estático: no requiere agente Java en WAR deployments -->
            <property name="eclipselink.weaving"                value="false"/>

            <!-- Connection pooling -->
            <property name="eclipselink.jdbc.batch-writing" value="Buffered"/>
            <property name="eclipselink.jdbc.batch-size"    value="100"/>

            <!-- Caché (opcional) -->
            <property name="eclipselink.cache.shared.default" value="false"/>
            <!-- Configuración para OpenLiberty -->
            <property name="eclipselink.target-server" value="Liberty"/>
        </properties>
    </persistence-unit>
</persistence>