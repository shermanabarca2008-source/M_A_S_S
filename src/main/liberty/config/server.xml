<server description="defaultServer">
    <featureManager>
        <feature>webProfile-10.0</feature>
    </featureManager>
    <basicRegistry id="defaultBasicRegistry" realm="BasicRealm">
        <user name="username" password="password" />
    </basicRegistry>
    <keyStore id="defaultKeyStore" password="password" />
    <httpEndpoint id="defaultHttpEndpoint" host="*" httpPort="9080" httpsPort="9443" />
    <webApplication location="M_A_S_S.war" contextRoot="/"/>

    <library id="postgresqlLib">
        <fileset dir="${server.config.dir}/postgresql" includes="*.jar"/>
    </library>

    <dataSource id="massDS" jndiName="jdbc/massDS">
        <jdbcDriver libraryRef="postgresqlLib"/>
        <properties.postgresql
                serverName="localhost"
                portNumber="5432"
                databaseName="M_A_S_S"
                user="mass"
                password="103125"/>
    </dataSource>
</server>
